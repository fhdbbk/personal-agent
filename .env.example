# Copy to `.env` (auto-loaded by pydantic-settings) and override as needed.

# Which LLM backend to use: ollama | anthropic | openai. See ADR 0007.
# Each provider reads only its own section below; the others are ignored.
PA_LLM_PROVIDER=ollama

# --- Ollama (active when PA_LLM_PROVIDER=ollama) --------------------

# Where Ollama listens. Default points at the local daemon.
PA_OLLAMA_HOST=http://localhost:11434

# Tag of the model to use. `ollama list` to see what's pulled.
PA_OLLAMA_MODEL=qwen3.5:4b

# Thinking mode. Qwen3 thinks before answering by default — accurate but slow.
# Set true when reasoning quality matters more than latency.
PA_OLLAMA_THINK=false

# Where to run inference: auto | cpu | gpu.
#   auto: let Ollama pick (uses GPU if it's available)
#   cpu : force num_gpu=0 (no GPU, even if one is available)
#   gpu : force max GPU layer offload
PA_OLLAMA_DEVICE=auto

# Context window in tokens. Ollama's default is 4096 — too small once tool
# results enter the conversation. 32768 is qwen2.5/3's native training window
# and a safe ceiling on a 16 GB laptop. Bump higher (e.g. 65536) only if you
# have the VRAM and accept YaRN-extension quality risk past 32k.
PA_OLLAMA_NUM_CTX=32768

# How long to wait on a single LLM call (seconds). Applied as the httpx timeout
# on the Ollama client, so for streamed calls this is a per-chunk idle timeout.
PA_REQUEST_TIMEOUT_S=60

# --- Anthropic (active when PA_LLM_PROVIDER=anthropic) --------------

# Anthropic API key. Required when the provider is anthropic; the adapter
# raises at startup if this is empty. Keep this file out of git — copy to
# .env (which is gitignored) before pasting a real key.
PA_ANTHROPIC_API_KEY=

# Model id. Aliases like `claude-haiku-4-5` resolve to the latest dated
# version; pin to a dated id (e.g. claude-haiku-4-5-20251001) for reproducibility.
PA_ANTHROPIC_MODEL=claude-haiku-4-5

# Required by the Messages API. Hard cap on output tokens per call; the
# tool-using loop typically generates short replies between tool calls so
# 4096 is generous.
PA_ANTHROPIC_MAX_TOKENS=4096

# --- OpenAI (active when PA_LLM_PROVIDER=openai) --------------------

# OpenAI API key. Required when the provider is openai; the adapter raises
# at startup if this is empty.
PA_OPENAI_API_KEY=

# Model id. gpt-4o-mini is the cheap default for tool-use; swap to gpt-4o
# or o-series models if quality matters more than cost.
PA_OPENAI_MODEL=gpt-4o-mini

# Phase 2 agent loop (see docs/decisions/0003-agent-loop.md).
# Sandbox root for read_file / write_file. Resolved relative to the cwd.
PA_AGENT_SANDBOX=sandbox
# Hard cap on agent iterations. Hitting this aborts the turn.
PA_AGENT_MAX_STEPS=8
# Consecutive failures of the same tool before the turn errors out.
PA_AGENT_MAX_RETRIES_PER_TOOL=2
# When true, approval-gated tools (write_file, python_exec) skip the user
# prompt. Useful for headless smoke runs; never enable on a shared machine.
PA_AGENT_AUTO_APPROVE=false

# Where rotating log files go. Daily rotation, 7 backups (so ~7 days of history).
PA_LOG_DIR=logs

# DEBUG / INFO / WARNING / ERROR.
PA_LOG_LEVEL=INFO
